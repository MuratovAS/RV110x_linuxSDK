#!/bin/sh
#
# ip6tables  Apply IPv6 firewall rules from /etc/ip6tables.conf at boot.
#

DAEMON="ip6tables"

start() {
	printf 'Starting %s: ' "$DAEMON"
	ip6tables-restore /etc/ip6tables.conf
	status=$?
	if [ "$status" -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return "$status"
}

stop() {
	printf 'Stopping %s: ' "$DAEMON"
	ip6tables -F
	status=$?
	if [ "$status" -eq 0 ]; then
		echo "OK"
	else
		echo "FAIL"
	fi
	return "$status"
}

restart() {
	stop
	sleep 1
	start
}

case "$1" in
	start|stop|restart)
		"$1";;
	reload)
		restart;;
	*)
		echo "Usage: $0 {start|stop|restart|reload}"
		exit 1
esac
